{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Exercism: configure (pick exercise)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\run-exercism-task.ps1",
        "configure",
        "${input:exercisePath}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Exercism: configure all tests (pick exercise)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\run-exercism-task.ps1",
        "configure-all-tests",
        "${input:exercisePath}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Exercism: build (run tests) (pick exercise)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\run-exercism-task.ps1",
        "build",
        "${input:exercisePath}"
      ],
      "dependsOn": "Exercism: configure all tests (pick exercise)",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "exercisePath",
      "type": "promptString",
      "description": "Path to exercise folder from workspace root (example: hello-world or cpp\\hello-world)",
      "default": "hello-world"
    }
  ]
}
